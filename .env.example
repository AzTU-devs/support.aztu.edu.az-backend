# ── AzTU Support API — environment configuration ──────────────────────────────
# Copy this file to `.env` and fill in real values. `.env` is git-ignored.

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# JDBC URL. For Neon, use the pooled host and append ?sslmode=require
DB_URL=jdbc:postgresql://localhost:5432/aztu_support?sslmode=require
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_POOL_SIZE=5

# ── JWT ───────────────────────────────────────────────────────────────────────
# Must be a long random string (>= 32 bytes). Generate: openssl rand -base64 48
JWT_SECRET=please-generate-a-long-random-secret-of-at-least-32-bytes
JWT_ACCESS_EXP_MINUTES=30
JWT_REFRESH_EXP_DAYS=14

# ── SMTP / Email ──────────────────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-smtp-username
MAIL_PASSWORD=your-smtp-app-password
MAIL_FROM=your-from-address@example.com
MAIL_FROM_NAME=AzTU Support
# Set to false to log emails to the console instead of sending them.
MAIL_ENABLED=true

# ── Business rules (configurable) ─────────────────────────────────────────────
ALLOWED_EMAIL_DOMAIN=aztu.edu.az
REQUIRE_EMAIL_VERIFICATION=true
PASSWORD_RESET_EXP_MINUTES=60
EMAIL_VERIFICATION_EXP_HOURS=48

# ── Frontend / CORS ───────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Server / storage ──────────────────────────────────────────────────────────
SERVER_PORT=8080
UPLOAD_DIR=./uploads
APP_LOG_LEVEL=INFO
